{
  "manifest_version": 3,
  "name": "Lottie JSON Viewer",
  "version": "1.0",
  "description": "Preview Lottie JSON animations.",
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["lottie.min.js", "popup.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": [],
  "icons": {
    "48": "icon.png"
  }
}
